{
  "dns": {
    "rules": [
      {
        "outbound": "any",
        "server": "local"
      },
      {
        "outbound": "direct",
        "server": "local"
      }
    ],
    "servers": [
      {
        "address": "https://1.1.1.2/dns-query",
        "tag": "remote"
      },
      {
        "address": "local",
        "detour": "direct",
        "tag": "local"
      }
    ],
    "strategy": "prefer_ipv6"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "xd",
      "external_ui_download_detour": "direct",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip"
    }
  },
  "inbounds": [
    {
      "address": [
        "fdfe:dcba:9876::1/126",
        "172.19.0.1/30"
      ],
      "auto_route": true,
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "localhost",
          "server_port": 7890
        }
      },
      "stack": "system",
      "strict_route": true,
      "type": "tun"
    },
    {
      "listen": "::",
      "listen_port": 7890,
      "type": "mixed"
    }
  ],
  "log": {
    "level": "fatal"
  },
  "outbounds": [
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "auto",
        "manual",
        "direct"
      ],
      "tag": "default",
      "type": "selector"
    },
    {
      "outbounds": [],
      "tag": "auto",
      "type": "urltest",
      "url": "https://chat.deepseek.com"
    },
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "💋 Telegram: @BreakRealFree"
      ],
      "tag": "manual",
      "type": "selector"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "💋 Telegram: @BreakRealFree",
      "type": "socks"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "block",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/block.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "block-nsfw",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/block-nsfw.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "proxy",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/proxy.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "proxy-cn",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/proxy-cn.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "direct",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/direct.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "direct-cn",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/direct-cn.srs"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "outbound": "direct",
        "protocol": "bittorrent"
      },
      {
        "action": "reject",
        "rule_set": [
          "block"
        ]
      },
      {
        "outbound": "default",
        "rule_set": [
          "proxy",
          "proxy-cn"
        ]
      },
      {
        "outbound": "direct",
        "rule_set": [
          "direct",
          "direct-cn"
        ]
      }
    ]
  }
}
