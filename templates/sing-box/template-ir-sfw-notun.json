{
  "dns": {
    "rules": [
      {
        "outbound": "any",
        "server": "local"
      },
      {
        "outbound": "direct",
        "server": "local"
      }
    ],
    "servers": [
      {
        "address": "https://1.1.1.3/dns-query",
        "tag": "remote"
      },
      {
        "address": "tls://free.shecan.ir",
        "address_resolver": "bootstrap",
        "detour": "direct",
        "tag": "local"
      },
      {
        "address": "local",
        "detour": "direct",
        "tag": "bootstrap"
      }
    ],
    "strategy": "prefer_ipv6"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "xd",
      "external_ui_download_detour": "direct",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip"
    }
  },
  "inbounds": [
    {
      "listen": "::",
      "listen_port": 7890,
      "set_system_proxy": true,
      "type": "mixed"
    }
  ],
  "log": {
    "level": "fatal"
  },
  "outbounds": [
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "auto",
        "manual",
        "direct"
      ],
      "tag": "default",
      "type": "selector"
    },
    {
      "outbounds": [],
      "tag": "auto",
      "type": "urltest",
      "url": "https://chat.deepseek.com"
    },
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "💋 Telegram: @BreakRealFree"
      ],
      "tag": "manual",
      "type": "selector"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "💋 Telegram: @BreakRealFree",
      "type": "socks"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "block",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/block.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "block-nsfw",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/block-nsfw.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "proxy",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/proxy.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "proxy-ir",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/proxy-ir.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "direct",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/direct.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "direct-ir",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/rule-sets/direct-ir.srs"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "outbound": "direct",
        "protocol": "bittorrent"
      },
      {
        "action": "reject",
        "rule_set": [
          "block",
	  "block-nsfw"
        ]
      },
      {
        "outbound": "default",
        "rule_set": [
          "proxy",
          "proxy-ir"
        ]
      },
      {
        "outbound": "direct",
        "rule_set": [
          "direct",
          "direct-ir"
        ]
      }
    ]
  }
}
