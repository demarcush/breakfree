{
  "dns": {
    "rules": [
      {
        "outbound": "any",
        "server": "local"
      }
    ],
    "servers": [
      {
        "address": "https://1.1.1.2/dns-query",
        "detour": "default",
        "tag": "remote"
      },
      {
        "address": "local",
        "tag": "local"
      }
    ],
    "strategy": "ipv4_only"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "xd",
      "external_ui_download_detour": "direct",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip"
    }
  },
  "inbounds": [
    {
      "listen": "::",
      "listen_port": 7890,
      "set_system_proxy": true,
      "type": "mixed"
    }
  ],
  "log": {
    "level": "fatal"
  },
  "outbounds": [
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "auto",
        "manual",
        "direct"
      ],
      "tag": "default",
      "type": "selector"
    },
    {
      "interval": "15m",
      "outbounds": [
        "💙 Telegram: @BreakRealFree"
      ],
      "tag": "auto",
      "type": "urltest",
      "url": "https://www.youtube.com/generate_204"
    },
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "💙 Telegram: @BreakRealFree"
      ],
      "tag": "manual",
      "type": "selector"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "server": "localhost",
      "server_port": 9050,
      "tag": "💙 Telegram: @BreakRealFree",
      "type": "socks"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "download_detour": "direct",
        "tag": "reject",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/reject.srs"
      },
      {
        "download_detour": "direct",
        "tag": "geosite-nsfw",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-nsfw.srs"
      },
      {
        "download_detour": "direct",
        "tag": "proxy",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/proxy.srs"
      },
      {
        "download_detour": "direct",
        "tag": "direct",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/direct.srs"
      },
      {
        "download_detour": "direct",
        "tag": "geoip-ir",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geoip-ir.srs"
      },
      {
        "download_detour": "direct",
        "tag": "geosite-ir",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-ir.srs"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "outbound": "direct",
        "protocol": [
          "bittorrent",
          "ntp"
        ]
      },
      {
        "action": "reject",
        "rule_set": [
          "reject",
          "geosite-nsfw"
        ]
      },
      {
        "outbound": "default",
        "rule_set": [
          "proxy"
        ]
      },
      {
        "outbound": "direct",
        "rule_set": [
          "direct",
          "geoip-ir",
          "geosite-ir"
        ]
      }
    ]
  }
}
