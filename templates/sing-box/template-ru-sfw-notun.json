{
  "certificate": {
    "store": "mozilla"
  },
  "dns": {
    "servers": [
      {
        "server": "8.8.8.8",
        "tag": "remote",
        "type": "https"
      },
      {
        "tag": "local",
        "type": "local"
      }
    ],
    "strategy": "prefer_ipv6"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "yacd",
      "external_ui_download_detour": "direct"
    }
  },
  "inbounds": [
    {
      "listen": "::",
      "listen_port": 7890,
      "set_system_proxy": true,
      "type": "mixed"
    }
  ],
  "log": {
    "level": "fatal"
  },
  "outbounds": [
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "auto",
        "manual",
        "direct"
      ],
      "tag": "default",
      "type": "selector"
    },
    {
      "interval": "15m",
      "outbounds": [],
      "tag": "auto",
      "type": "urltest",
      "url": "https://web.dev"
    },
    {
      "interrupt_exist_connections": true,
      "outbounds": [
        "💋 Telegram: @BreakRealFree"
      ],
      "tag": "manual",
      "type": "selector"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "💋 Telegram: @BreakRealFree",
      "type": "socks"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "rule_set": [
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "reject",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/reject.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "geosite-nsfw",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-nsfw.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "proxy",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/proxy.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "direct",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/demarcush/breakfree@master/release/rule-sets/direct.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "geoip-ru",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geoip-ru.srs"
      },
      {
        "download_detour": "direct",
        "format": "binary",
        "tag": "geosite-category-ru",
        "type": "remote",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-category-ru.srs"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "outbound": "direct",
        "protocol": [
          "bittorrent",
          "ntp"
        ]
      },
      {
        "action": "reject",
        "rule_set": [
          "reject",
          "geosite-nsfw"
        ]
      },
      {
        "outbound": "default",
        "rule_set": "proxy"
      },
      {
        "outbound": "direct",
        "rule_set": [
          "direct",
          "geoip-ru",
          "geosite-category-ru"
        ]
      }
    ]
  }
}
